{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],
  "agent": {
    "build": {
      "prompt": "CRITICAL: You MUST follow all instructions in AGENTS.md files at all times without exception. The 4-line limit (excluding tool use and code output) is absolute. Never defer, ask questions, or suggest alternatives when the user gives a direct instruction — execute it."
    },
    "plan": {
      "prompt": "CRITICAL: You MUST follow all instructions in AGENTS.md files at all times without exception. The 4-line limit (excluding tool use and code output) is absolute. Never defer, ask questions, or suggest alternatives when the user gives a direct instruction — execute it."
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "git add*": "deny",
      "git commit*": "deny",
      "git push*": "deny",
      "git merge*": "deny",
      "git rebase*": "deny",
      "git checkout*": "deny",
      "git reset*": "deny",
      "git revert*": "deny",
      "git branch*": "deny",
      "git stash*": "deny",
      "git tag*": "deny",
      "git cherry-pick*": "deny",
      "git am*": "deny",
      "git rm*": "deny",
      "git mv*": "deny",
      "git clean*": "deny",
      "git submodule*": "deny",
      "git worktree*": "deny",
      "git config*": "deny",
      "git update-ref*": "deny",
      "git symbolic-ref*": "deny",
      "git fetch*": "deny",
      "git pull*": "deny",
      "git clone*": "deny",
      "git init*": "deny",
      "git notes*": "deny",
      "git replace*": "deny",
      "git gc*": "deny",
      "git prune*": "deny",
      "git fsck*": "deny",
      "git archive*": "deny",
      "git bundle*": "deny",
      "git remote add*": "deny",
      "git remote remove*": "deny",
      "git remote rename*": "deny",
      "git remote set-url*": "deny",
      "git reflog delete*": "deny",
      "git reflog expire*": "deny",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git blame*": "allow",
      "git grep*": "allow",
      "git describe*": "allow",
      "git rev-parse*": "allow",
      "git rev-list*": "allow",
      "git ls-tree*": "allow",
      "git ls-files*": "allow",
      "git cat-file*": "allow",
      "git shortlog*": "allow",
      "git name-rev*": "allow",
      "git branch --list*": "allow",
      "git stash list*": "allow",
      "git tag --list*": "allow",
      "git remote -v*": "allow"
    }
  }
}
